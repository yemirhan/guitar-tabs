---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/support', label: 'Support' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
];
---

<header class="border-b border-gray-100">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight">
      <img src="/icon.png" alt="Guitar Tab Reader icon" width="28" height="28" class="rounded-md" />
      Guitar Tab Reader
    </a>
    <ul class="flex gap-6 text-sm text-gray-600">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="hover:text-gray-900 transition-colors">{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

{
  "expo": {
    "name": "Guitar Tab Reader",
    "slug": "guitar-tab-reader",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "gtr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yemirhan.guitartabreader",
      "appleTeamId": "8RD344SHFZ",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4aa83b6f-b008-4827-b116-83815c11cb33"
      }
    }
  }
}
